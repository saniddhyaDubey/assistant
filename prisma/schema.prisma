generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DailyLog {
  id                String   @id @default(cuid())
  date              String   @unique // YYYY-MM-DD
  mits              Json     @default("[]")
  routineChecklist  Json     @default("[]")
  dietChecklist     Json     @default("[]")
  brainDump         String?
  sideQuests        String?
  workNotes         String?
  takeaways         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model InboxItem {
  id        String   @id @default(cuid())
  text      String
  date      String // YYYY-MM-DD, day of capture
  sorted    Boolean  @default(false)
  createdAt DateTime @default(now())
}
